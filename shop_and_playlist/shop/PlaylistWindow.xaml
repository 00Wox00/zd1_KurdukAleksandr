<Window x:Class="shop.PlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Плейлист" Height="520" Width="450">
    <StackPanel>

        <!-- Верхнее меню -->
        <Menu>
            <MenuItem Header="Задания">
                <MenuItem Header="Задание 1 — Магазин" Click="OpenShop_Click"/>
                <MenuItem Header="Задание 2 — Плейлист" Click="OpenPlaylist_Click"/>
            </MenuItem>
        </Menu>

        <StackPanel Margin="10">
            <!-- Поля для добавления песни -->
            <TextBlock Text="Автор:"/>
            <TextBox x:Name="txtAuthor" Margin="0,0,0,5"/>

            <TextBlock Text="Название:"/>
            <TextBox x:Name="txtTitle" Margin="0,0,0,5"/>

            <TextBlock Text="Файл:"/>
            <TextBox x:Name="txtFilename" Margin="0,0,0,5"/>

            <Button Content="Добавить песню" Click="Add_Click" Margin="0,0,0,10"/>

            <!-- Список песен -->
            <ListBox x:Name="lstSongs" Height="150" Margin="0,0,0,10"/>

            <!-- Навигация -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button Content="◀◀ В начало" Click="GoToStart_Click" Margin="5"/>
                <Button Content="◀ Пред." Click="Previous_Click" Margin="5"/>
                <Button Content="След. ▶" Click="Next_Click" Margin="5"/>
            </StackPanel>

            <!-- Переход по индексу -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Перейти к индексу:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtIndex" Width="50" Margin="0,0,5,0"/>
                <Button Content="Перейти" Click="GoTo_Click"/>
            </StackPanel>

            <!-- Удаление по индексу -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Удалить по индексу:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtRemoveIndex" Width="50" Margin="0,0,5,0"/>
                <Button Content="Удалить" Click="Remove_Click"/>
            </StackPanel>

            <Button Content="Очистить плейлист" Click="Clear_Click" Margin="0,0,0,10"/>

            <!-- Текущая песня и статус -->
            <TextBlock x:Name="txtCurrent" Text="Текущая: —" FontWeight="Bold"/>
            <TextBlock x:Name="txtStatus" Foreground="Red"/>
        </StackPanel>

    </StackPanel>
</Window>