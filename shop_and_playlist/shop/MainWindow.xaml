<Window x:Class="shop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Главное меню" Height="500" Width="450">
    <DockPanel>
        <!-- Меню сверху -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Задания">
                <MenuItem Header="Задание 1 — Магазин" Click="OpenShop_Click"/>
                <MenuItem Header="Задание 2 — Плейлист" Click="OpenPlaylist_Click"/>
            </MenuItem>
        </Menu>

        <!-- Контейнер для переключения содержимого -->
        <ContentControl x:Name="MainContent" Margin="10"/>
    </DockPanel>
</Window>